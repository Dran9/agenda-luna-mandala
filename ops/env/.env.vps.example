COMPOSE_PROJECT_NAME=agenda-luna-prod

VPS_CADDY_SITE_ADDRESS=api.example.com
VPS_CADDY_API_UPSTREAM=api:3000
VPS_HTTP_PORT=80
VPS_HTTPS_PORT=443

VPS_API_IMAGE=ghcr.io/OWNER/REPO:COMMIT_SHA
VPS_APP_ENV=production

VPS_DB_ROOT_PASSWORD=change-me-root
VPS_DB_USER=agenda_luna_app
VPS_DB_PASSWORD=change-me-app
VPS_DB_NAME=agenda_luna
VPS_DB_CONNECTION_LIMIT=10
VPS_DB_TIMEZONE=-04:00
VPS_APP_TIMEZONE=America/La_Paz

VPS_JWT_SECRET=change-me-long-random-secret
VPS_MESSAGING_PROVIDER=test_outbox
VPS_ENABLE_MOCK_FALLBACK=false
VPS_ENABLE_DEMO_SCHEDULE_FALLBACK=false

VPS_API_CORS_ORIGINS=https://agenda.example.com,https://admin.example.com
VPS_PUBLIC_BASE_URL=https://agenda.example.com
VPS_ADMIN_BASE_URL=https://admin.example.com
VPS_SENTRY_DSN=
VPS_SENTRY_RELEASE=

VPS_WA_TOKEN=
VPS_WA_PHONE_ID=
VPS_WA_VERIFY_TOKEN=
VPS_META_APP_SECRET=
VPS_GOOGLE_VISION_API_KEY=
VPS_TELEGRAM_BOT_TOKEN=

VPS_LOG_MAX_SIZE=10m
VPS_LOG_MAX_FILE=5
