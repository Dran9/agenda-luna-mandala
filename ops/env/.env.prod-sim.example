COMPOSE_PROJECT_NAME=agenda-prod-sim

VPS_CADDY_SITE_ADDRESS=:80
VPS_CADDY_API_UPSTREAM=api:3000
VPS_HTTP_PORT=8080
VPS_HTTPS_PORT=8443

VPS_API_IMAGE=agendalunamandala-api:latest
VPS_APP_ENV=production

VPS_DB_ROOT_PASSWORD=agenda_root_prod_sim
VPS_DB_USER=lunav2_prod_sim_user
VPS_DB_PASSWORD=lunav2_prod_sim_password
VPS_DB_NAME=lunamandala_v2_prod_sim
VPS_DB_CONNECTION_LIMIT=10
VPS_DB_TIMEZONE=-04:00
VPS_APP_TIMEZONE=America/La_Paz

VPS_JWT_SECRET=prod-sim-local-change-me
VPS_MESSAGING_PROVIDER=test_outbox
VPS_ENABLE_MOCK_FALLBACK=false
VPS_ENABLE_DEMO_SCHEDULE_FALLBACK=false

VPS_API_CORS_ORIGINS=http://127.0.0.1:8080
VPS_PUBLIC_BASE_URL=http://127.0.0.1:8080
VPS_ADMIN_BASE_URL=http://127.0.0.1:8080/admin/
VPS_SENTRY_DSN=
VPS_SENTRY_RELEASE=

VPS_WA_TOKEN=
VPS_WA_PHONE_ID=
VPS_WA_VERIFY_TOKEN=
VPS_META_APP_SECRET=
VPS_GOOGLE_VISION_API_KEY=
VPS_TELEGRAM_BOT_TOKEN=

VPS_LOG_MAX_SIZE=10m
VPS_LOG_MAX_FILE=5
